# Copy this file to .env and fill in the value below.
# .env is gitignored; .env.example is the template committed to the repo.

# Groq API key — https://console.groq.com/keys
# EXPO_PUBLIC_ prefix is required so Expo inlines it into the JS bundle.
# Note: anything with EXPO_PUBLIC_ ships in the bundle and is extractable —
# fine for dev/MVP, move behind a server proxy before any public release.
EXPO_PUBLIC_GROQ_API_KEY=gsk_your_key_here
